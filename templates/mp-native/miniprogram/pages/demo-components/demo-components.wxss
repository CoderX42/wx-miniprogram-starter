.container {
  padding: 32rpx 24rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-family: "PFS";
  font-size: var(--font-base);
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--color-primary);
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
  font-family: "PFR";
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.muted {
  color: var(--color-text-tertiary);
  font-family: "PFR";
  font-size: var(--font-sm);
}

.btn {
  display: inline-block;
  padding: 16rpx 32rpx;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: var(--radius-md);
  text-align: center;
  font-family: "PFM";
  font-size: var(--font-sm);
}

.mt-16 {
  margin-top: 16rpx;
}

.popup-inner {
  padding: 48rpx 32rpx;
  text-align: center;
  min-width: 560rpx;
}

.popup-title {
  font-family: "PFS";
  font-size: var(--font-lg);
  margin-bottom: 24rpx;
}

.popup-text {
  font-family: "PFR";
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
}
