/* ============================================================
   欢迎页 — Editorial / Specimen-sheet 风格
   关键约束：WXSS 在 rpx 单位下，glass-easel 支持 grid / gradient
   ============================================================ */

.container {
  padding: 16rpx 40rpx 96rpx;
  min-height: 100vh;
  background:
    radial-gradient(120% 60% at 100% 0%, rgba(234, 78, 130, 0.04) 0%, transparent 60%),
    linear-gradient(180deg, #ffffff 0%, var(--color-bg) 70%);
  display: flex;
  flex-direction: column;
}

/* ---------- 入场动画：错落浮现 ---------- */
@keyframes rise {
  from {
    opacity: 0;
    transform: translateY(28rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes draw {
  from { transform: scaleX(0); }
  to { transform: scaleX(1); }
}

.meta-row,
.display-line,
.intro,
.rule,
.nav-item,
.footer {
  opacity: 0;
  animation: rise 0.55s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
}

/* ---------- 顶部元信息条 ---------- */
.meta-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 16rpx;
  margin-bottom: 56rpx;
  animation-delay: 0.05s;
}

.meta-no {
  font-family: 'PFM';
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-text-primary);
}

.meta-rule {
  flex: 1;
  height: 1rpx;
  background: var(--color-border);
  transform-origin: left center;
  animation: draw 1.1s cubic-bezier(0.7, 0, 0.3, 1) 0.05s forwards;
  opacity: 1;
}

.meta-tag {
  font-family: 'PFM';
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: var(--color-text-tertiary);
}

/* ---------- 巨型显示标题 ---------- */
.display {
  margin-bottom: 56rpx;
}

.display-line {
  display: block;
  font-family: 'PFS';
  font-size: 112rpx;
  line-height: 1.05;
  letter-spacing: -2rpx;
  color: var(--color-text-primary);
}

.display-line.d-1 { animation-delay: 0.15s; }
.display-line.d-2 {
  animation-delay: 0.25s;
  padding-left: 12rpx;
  color: var(--color-text-secondary);
}
.display-line.d-3 {
  animation-delay: 0.35s;
  display: flex;
  align-items: flex-end;
}

.period {
  display: inline-block;
  font-size: 112rpx;
  line-height: 0.6;
  color: var(--color-primary);
  margin-left: 8rpx;
  transform: translateY(-12rpx);
}

/* ---------- 副标题区 ---------- */
.intro {
  display: flex;
  align-items: stretch;
  gap: 24rpx;
  margin-bottom: 32rpx;
  animation-delay: 0.45s;
}

.accent {
  width: 6rpx;
  background: var(--color-primary);
  border-radius: 3rpx;
}

.intro-body {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 8rpx 0;
}

.intro-title {
  font-family: 'PFM';
  font-size: 32rpx;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.intro-meta {
  font-family: 'PFR';
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  letter-spacing: 1rpx;
}

/* ---------- 分割线 ---------- */
.rule {
  height: 1rpx;
  background: var(--color-border);
  margin: 16rpx 0 12rpx;
  animation-delay: 0.55s;
}

.rule--soft {
  background: var(--color-border-light);
  margin: 32rpx 0 20rpx;
}

/* ---------- 编号导航列表 ---------- */
.nav {
  display: flex;
  flex-direction: column;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 36rpx 12rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  position: relative;
  transition: opacity 0.15s ease, background-color 0.2s ease;
}

.nav-item:last-child { border-bottom: none; }

.nav-item:nth-child(1) { animation-delay: 0.65s; }
.nav-item:nth-child(2) { animation-delay: 0.73s; }
.nav-item:nth-child(3) { animation-delay: 0.81s; }

/* 按压反馈：仅用 opacity + 背景色变化，不改变布局位置 */
.nav-item--active {
  background: linear-gradient(90deg, rgba(234, 78, 130, 0.06) 0%, transparent 70%);
  opacity: 0.6;
}

.nav-num {
  font-family: 'PFM';
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: var(--color-text-tertiary);
  width: 64rpx;
  flex-shrink: 0;
}

.nav-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.nav-title {
  font-family: 'PFM';
  font-size: 32rpx;
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
}

.nav-desc {
  font-family: 'PFR';
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

/* ---------- 自定义箭头（线 + 头） ---------- */
.nav-arrow {
  display: flex;
  align-items: center;
  position: relative;
  width: 56rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.arrow-bar {
  position: absolute;
  left: 0;
  top: 50%;
  width: 100%;
  height: 1rpx;
  background: var(--color-text-primary);
  transform: translateY(-0.5rpx);
  transition: width 0.3s cubic-bezier(0.2, 0.7, 0.2, 1), background 0.3s ease;
}

.arrow-head {
  position: absolute;
  right: 0;
  top: 50%;
  width: 14rpx;
  height: 14rpx;
  border-top: 1rpx solid var(--color-text-primary);
  border-right: 1rpx solid var(--color-text-primary);
  transform: translate(0, -50%) rotate(45deg);
  transition: transform 0.3s cubic-bezier(0.2, 0.7, 0.2, 1), border-color 0.3s ease;
}

.nav-item--active .arrow-bar {
  background: var(--color-primary);
}

.nav-item--active .arrow-head {
  border-color: var(--color-primary);
  /* 不再做水平位移，避免按压时布局抖动；只保留颜色变化 */
  transform: translate(0, -50%) rotate(45deg);
}

/* ---------- 底部 ---------- */
.footer {
  margin-top: auto;
  padding-top: 8rpx;
  animation-delay: 0.92s;
}

.footer-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 4rpx;
}

.footer-mark {
  font-family: 'PFR';
  font-size: 20rpx;
  letter-spacing: 1.5rpx;
  color: var(--color-text-tertiary);
}
