.error-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  color: var(--color-text-tertiary);
  font-family: "PFR";
  font-size: var(--font-sm);
}

.error-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-warning);
  color: var(--color-text-inverse);
  font-size: 60rpx;
  font-family: "PFS";
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.error-text {
  margin-bottom: 24rpx;
  text-align: center;
}

.error-btn {
  margin-top: 16rpx;
  padding: 16rpx 48rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-sm);
  font-family: "PFM";
}
