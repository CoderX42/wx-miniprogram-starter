.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  color: var(--color-text-tertiary);
  font-family: "PFR";
  font-size: var(--font-sm);
}

.loading-page {
  min-height: 60vh;
  flex-direction: column;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 16rpx;
}

.loading-page .loading-spinner {
  margin-right: 0;
  margin-bottom: 16rpx;
  width: 48rpx;
  height: 48rpx;
}

.loading-text {
  text-align: center;
}
