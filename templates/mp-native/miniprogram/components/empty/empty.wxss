.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  color: var(--color-text-tertiary);
  font-family: "PFR";
  font-size: var(--font-sm);
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-image image {
  width: 100%;
  height: 100%;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--color-border-light);
  opacity: 0.5;
}

.empty-text {
  margin-bottom: 24rpx;
  text-align: center;
}

.empty-btn {
  margin-top: 16rpx;
  padding: 16rpx 48rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-sm);
  font-family: "PFM";
}
